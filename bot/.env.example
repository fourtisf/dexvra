# ── Dexvra Telegram Bot — copy to .env (gitignored; NEVER commit real values) ──

# ── Telegram ─────────────────────────────────────────────────────────────────
BOT_TOKEN=                       # @BotFather token for the main bot
ADMIN_BOT_TOKEN=                 # @BotFather token for the admin/template-editor bot (optional)
ANNOUNCE_CHANNEL=@dexvraio        # announcement channel (bot must be admin)
TRENDING_CHANNEL=@dexvratrending  # trending channel
LISTING_CHANNEL=@dexvralisting    # listing-alert channel
LOG_CHANNEL=                      # optional: channel id for visitor + event logs (/start, purchases)
PK_CHANNEL=                       # optional: PRIVATE channel id for temp-wallet private-key backups (bot must be admin)
ADMIN_IDS=                        # comma-separated numeric Telegram user ids (these pay 0 / test free)

# ── Token logo → animated custom-emoji packs (optional) ──────────────────────
# Each listing's logo becomes an animated custom emoji in a per-token pack
# ("SYMBOL by @dexvralisting"), shown inline in channel posts via GramJS.
# Packs are owned by the ADMIN bot; needs an anchor user that has /start'ed it.
# TOKEN_PACK_BOT_TOKEN=           # defaults to ADMIN_BOT_TOKEN
# TOKEN_PACK_USER_ID=             # defaults to the first ADMIN_IDS entry
# TOKEN_PACK_TITLE_SUFFIX=        # defaults to " by @dexvralisting"
ADMIN_USERNAMES=                  # comma-separated @usernames (case-insensitive)

# ── Premium emoji (GramJS / MTProto) ─────────────────────────────────────────
# Channel posts are sent from a Telegram PREMIUM user account so premium custom
# emoji render animated. 1) create API creds at https://my.telegram.org/apps
# (log in with the premium account), 2) run `node scripts/gramjs-login.js` once
# on the server, 3) make the account able to post in all three channels.
# Without these the bot falls back to Bot API (plain unicode emoji) — no outage.
API_ID=                           # from my.telegram.org/apps
API_HASH=                         # from my.telegram.org/apps
GRAMJS_SESSION_FILE=              # default: <bot>/session.txt (created by the login script)
GRAMJS_ENABLED=1                  # set 0 to force Bot API posting
# Turn premium custom emoji ON in channel posts. Needs BOTH this flag AND a
# Premium GramJS session above; without the session it silently stays unicode.
# Read at module load — restart the bot after changing (template refresh won't).
PREMIUM_EMOJI=1

# ── Dexvra web app (internal API) ────────────────────────────────────────────
SITE_URL=https://dexvra.io
DEXVRA_API_BASE=http://127.0.0.1:3005   # where the Next.js app listens (same VPS)
INTERNAL_API_TOKEN=               # MUST equal the web app's INTERNAL_API_TOKEN (>= 24 chars)

# ── Payment (temp wallet + poll) ─────────────────────────────────────────────
PAYMENT_POLL_MS=3000              # balance poll interval (clamped 1500–10000)
PAYMENT_TIMEOUT_MS=300000         # give up polling after this (5 min)
PAYMENT_TOLERANCE_PCT=0           # accept payments this % under quote (dust tolerance)

# RPC endpoints — public defaults are baked in; override for reliability/limits.
RPC_ETHEREUM=
RPC_BSC=
RPC_BASE=
RPC_ROBINHOOD=
RPC_SOLANA=
RPC_TRON=
RPC_TON=
TON_API_KEY=                      # toncenter.com API key (recommended for TON)

# ── Treasury (sweep destinations) ────────────────────────────────────────────
# After a payment clears, funds sweep to these. Leave a chain BLANK to skip the
# sweep for it (funds stay in the per-order temp wallet, whose key is stored in
# .keys/). Set these before going live.
TREASURY_EVM=                     # one address for ethereum / bsc / base / robinhood
TREASURY_SOL=
TREASURY_TRON=
TREASURY_TON=

# ── Temp-wallet key storage ──────────────────────────────────────────────────
# WALLETS_DIR=./.keys
WALLET_ENC_KEY=                   # 64-hex (32-byte) AES-256-GCM key to encrypt stored keys at rest

# ── MongoDB durable mirror (optional; recommended for production) ─────────────
# When set, all bot state (the /start audience, orders, templates, group +
# banner config, dedup latches) is mirrored to MongoDB so it survives a VPS
# reset / container replace instead of living only on local disk. Reads still
# use local files; at boot any store missing on disk is restored from Mongo.
# Leave BLANK to run on local files only (no outage). Point BOTH bots (main +
# admin) at the SAME MONGO_URI so they share one durable store.
MONGO_URI=                        # e.g. mongodb+srv://user:pass@cluster.mongodb.net/dexvra
# MONGO_DB=dexvra                 # optional; defaults to the db name in MONGO_URI

# ── Twitter / X (leave the 4 listing keys blank to keep X posting OFF) ────────
X_ENABLED=1
X_HANDLE=dexvra
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Optional second "official" account for announcements:
X_O_API_KEY=
X_O_API_KEY_SECRET=
X_O_ACCESS_TOKEN=
X_O_ACCESS_SECRET=

# ── Background services ──────────────────────────────────────────────────────
TRENDING_POST_MS=300000           # trending list refresh cadence
TRENDING_SWEEP_MS=60000           # clear expired trending slots
PUMP_CHECK_MS=180000              # pump-alert poll cadence
PUMP_ENABLED=1

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_WINDOW=3000
RATE_LIMIT=20

# ── Admin broadcast (compose in @dexvraadminbot → delivered by the main bot) ──
BROADCAST_RATE=20          # messages/sec (Telegram allows ~30/s to distinct users; max 28)
BROADCAST_CONCURRENCY=8    # parallel in-flight sends
BROADCAST_POLL_MS=5000     # how often the main bot picks up a queued broadcast
